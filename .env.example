# ─────────────────────────────────────────────────────────────
# Root infrastructure variables (consumed by docker-compose.yml)
# Copy to .env:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=homedispatcher
POSTGRES_PASSWORD=homedispatcher
POSTGRES_DB=homedispatcher
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
