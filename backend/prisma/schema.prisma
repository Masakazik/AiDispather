// ДомДиспетчер — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISPATCHER
  TECHNICIAN
  RESIDENT
}

enum RequestStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  WAITING
  DONE
  CLOSED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RequestSource {
  MAX
  TELEGRAM
  PHONE
  WIDGET
  MANUAL
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  phone        String?
  role         UserRole @default(DISPATCHER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignedRequests ServiceRequest[] @relation("AssignedTo")
  createdRequests  ServiceRequest[] @relation("CreatedBy")

  @@map("users")
}

model Building {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  apartments Apartment[]
  requests   ServiceRequest[]

  @@map("buildings")
}

model Apartment {
  id         String   @id @default(uuid())
  number     String
  floor      Int?
  buildingId String   @map("building_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  building Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  requests ServiceRequest[]

  @@unique([buildingId, number])
  @@map("apartments")
}

model ServiceRequest {
  id          String          @id @default(uuid())
  // Human-friendly sequential number (e.g. 10259) shown as "#10259" in the UI.
  // Values are drawn from the Postgres sequence `hd_request_number_seq`.
  number      Int             @unique
  title       String
  description String?
  status      RequestStatus   @default(NEW)
  priority    RequestPriority @default(MEDIUM)
  source      RequestSource   @default(MANUAL)
  category    String?

  // Reporter details captured from the messenger/bot or a manual entry.
  residentName   String? @map("resident_name")
  residentPhone  String? @map("resident_phone")
  apartmentLabel String? @map("apartment_label")
  // Display name of the assignee (real technician accounts come later).
  assigneeName   String? @map("assignee_name")
  // MAX group chat + user ids, used to de-duplicate leads per resident.
  externalChatId String? @map("external_chat_id")
  externalUserId String? @map("external_user_id")

  buildingId  String?    @map("building_id")
  apartmentId String?    @map("apartment_id")
  assignedToId String?   @map("assigned_to_id")
  createdById  String?   @map("created_by_id")

  building   Building?  @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  apartment  Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  assignedTo User?      @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User?      @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([source])
  @@index([externalChatId])
  @@index([externalChatId, externalUserId])
  @@map("service_requests")
}

enum EmployeePresence {
  ONLINE
  AWAY
  OFFLINE
}

model Employee {
  id          String           @id @default(uuid())
  name        String
  role        String
  phone       String?
  presence    EmployeePresence @default(ONLINE)
  activeCount Int              @default(0) @map("active_count")
  doneCount   Int              @default(0) @map("done_count")
  rating      Float            @default(5)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@map("employees")
}

model Task {
  id           String          @id @default(uuid())
  title        String
  assigneeName String?         @map("assignee_name")
  dueDate      DateTime?       @map("due_date")
  priority     RequestPriority @default(MEDIUM)
  done         Boolean         @default(false)
  createdById  String?         @map("created_by_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([dueDate])
  @@index([done])
  @@map("tasks")
}

model Document {
  id         String   @id @default(uuid())
  name       String
  type       String
  sizeLabel  String   @map("size_label")
  mimeType   String   @map("mime_type")
  storedPath String   @map("stored_path")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("documents")
}
