# ─────────────────────────────────────────────────────────────
# Backend (NestJS) environment
# Copy to backend/.env:  cp backend/.env.example backend/.env
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
# Local dev (npm run dev on host): use localhost
# Docker app container: overridden in docker-compose.yml to host `postgres`
DATABASE_URL=postgresql://homedispatcher:homedispatcher@localhost:5432/homedispatcher?schema=public

# Redis (caching + BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=1d

# Cache TTL in seconds
CACHE_TTL=60

# MAX messenger bot webhook shared secret (legacy HTTP integration endpoint)
MAX_WEBHOOK_SECRET=dev-max-webhook-secret

# MAX bot (group chat triage + tickets)
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_BOT_TOKEN=
MAX_MODE=webhook
MAX_LONG_POLLING_TIMEOUT_SEC=25

# Yandex AI (prompt-based triage)
YANDEX_AI_API_KEY=
YANDEX_AI_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_AI_PROJECT_ID=
YANDEX_AI_PROMPT_ID=
