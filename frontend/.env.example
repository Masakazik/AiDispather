# ─────────────────────────────────────────────────────────────
# Frontend (Vite) environment
# Copy to frontend/.env:  cp frontend/.env.example frontend/.env
# Only variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Base URL for the REST API. In dev, requests to /api are proxied
# to VITE_API_PROXY_TARGET by Vite (see vite.config.ts).
VITE_API_BASE_URL=/api

# Dev-only: where the Vite proxy forwards /api requests.
VITE_API_PROXY_TARGET=http://localhost:4000
